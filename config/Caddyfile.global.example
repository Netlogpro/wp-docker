# Generated by wp.sh for ./wp.sh global-ssl (Let's Encrypt).
# Do not edit by hand — re-run ./wp.sh global-ssl to regenerate.
#
# Requirements:
#   - WP_SITE_URL must be a public hostname with DNS pointing at this machine
#   - Ports 80 and 443 must be reachable from the internet
#   - WP_ADMIN_EMAIL must be a real address (used for Let's Encrypt registration)

{
	email {$WP_ADMIN_EMAIL}
}

{$SITE_HOST} {
	encode gzip
	reverse_proxy wordpress:80
}
