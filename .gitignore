# Local environment overrides
.env

# Extra plugin archives dropped into the test stack (keep the folder itself)
/plugins/*
!/plugins/.gitkeep

# Must-use plugin archives / files (keep the folder itself)
/mu-plugins/*
!/mu-plugins/.gitkeep

# Theme archives / folders (keep the folder itself)
/themes/*
!/themes/.gitkeep

# wp-config local overrides (tracked templates live in config/)
/config/wp-config.extra.php
/config/wp-config.d/*
!/config/wp-config.d/.gitkeep
