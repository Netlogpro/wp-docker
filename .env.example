# Copy this file to .env (in this same docker/ directory) and adjust as needed.
# `docker compose` and wp.sh both read it automatically.

# --- Ports -------------------------------------------------------------
WORDPRESS_PORT=8080

# --- WordPress image -----------------------------------------------------
# Base image tag used by Dockerfile (WordPress + PHP + Apache).
WORDPRESS_IMAGE=wordpress:7.0.0-php8.2-apache

# --- Database ------------------------------------------------------------
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=wordpress
MYSQL_ROOT_PASSWORD=root

# --- WordPress site / admin user -----------------------------------------
WP_SITE_TITLE="Wordpress Test Site"
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=admin@example.com

# Optional. Site domain or URL (e.g. newsite.local or http://newsite.local:8080).
# Leave blank to use http://localhost:WORDPRESS_PORT. If no port is given and
# WORDPRESS_PORT is not 80, wp.sh appends :WORDPRESS_PORT automatically.
# When set, wp.sh updates siteurl/home in the container on each run.
# Add the hostname to /etc/hosts on your machine (e.g. 127.0.0.1 newsite.local).
WP_SITE_URL=

# --- Theme ---------------------------------------------------------------
# Optional. Theme slug (folder name) to activate after themes/ are installed.
# Leave blank to keep the current active theme unchanged.
WP_DEFAULT_THEME=